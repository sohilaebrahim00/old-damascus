# ============================================================
# OLD DAMASCUS MEDITERRANEAN RESTAURANT — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.

# ---- Site / App URL ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Clover Integration ----
CLOVER_ENV=production
CLOVER_MERCHANT_ID=
CLOVER_ACCESS_TOKEN=
NEXT_PUBLIC_CLOVER_PUBLIC_TOKEN=
CLOVER_PRIVATE_TOKEN=
CLOVER_PICKUP_ORDER_TYPE_ID=
CLOVER_DELIVERY_ORDER_TYPE_ID=
CLOVER_WEBHOOK_SECRET=

# ---- Email (Resend) ----
RESEND_API_KEY=
CONTACT_RECIPIENT_EMAIL=info@olddamascustx.com
CATERING_RECIPIENT_EMAIL=info@olddamascustx.com
RESEND_API_KEY=  
ADMIN_NOTIFICATION_EMAIL= 
